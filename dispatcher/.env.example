# 登录认证（必须修改）
JWT_SECRET=please-change-this-secret-key
JWT_EXPIRE_HOURS=72
AUTH_CAPTCHA_TTL_SECONDS=300
AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
AUTH_LOGIN_LOCK_SECONDS=900

# 首次空库时写入 admin 密码（单机/自举必填其一；与 Portal set-admin-password 二选一亦可）
# 未配置且库内尚无 auth_credentials 时，登录不接受弱口令 admin/admin
# VAITEAM_INITIAL_ADMIN_PASSWORD=

# SaaS：Portal / install-agent 调本机内部接口（请求头 X-Portal-Service-Token 须与本值一致）。
# 须与 Portal 该租户 meta.portal_service_token 解密明文一致；未配置则 /api/internal/portal/* 一律 503。
# 标准安装：install.sh 将环境变量写入 compose/shared/.env，由 docker-compose.install.yml 注入 dispatcher；勿依赖用户进容器手改。
# set-admin-password、bootstrap-managed-infra（全托管默认环境组）
# VAITEAM_PORTAL_SERVICE_TOKEN=

# ── 登录页「忘记密码」发邮件（与 Portal 共用 SMTP_* 命名；须与库内 auth_owner_contact 登记邮箱一致）──
# SMTP_ENABLED=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=VAI TEAM
# SMTP_USE_TLS=1
# SMTP_USE_SSL=0
# 邮件内重置链接的站点根（反代/API 域名与浏览器域名不一致时必填）
# AUTH_PASSWORD_RESET_PUBLIC_BASE_URL=https://qingfeng.vaiteam.cn
# AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# ── 原型 CC：runs/start 时在项目「执行环境组」节点上 docker compose 拉起 Worker（须 SSH 可达 + 节点在线）──
# 容器内回调与拉包须用浏览器/内网可达的 Dispatcher 根 URL（含协议与端口）；未配置则仅登记 run，不远程拉起。
# DISPATCHER_PUBLIC_BASE_URL=http://DISPATCHER_HOST_PLACEHOLDER:13000
# PROTOTYPE_CC_WORKER_IMAGE=openclaw/prototype-cc-worker:latest
